# --- UNCOMMENT THIS TO LAUNCH ALVAR DETECTION ---
MARKER_SIZE=18.0
MAX_NEW_MARKER_ERROR=0.08
MAX_TRACK_ERROR=0.2

# --- Camera 1 (External Camera) ---
# --- UNCOMMENT THIS TO LAUNCH THIS CAMERA ---
CAMERA1_NAME=table_realsense
CAMERA1_NAMESPACE=table_realsense
CAMERA1_TF_PREFIX=table_realsense
CAMERA1_RELATIVE_TO_ROBOT=false
CAMERA1_SERIAL_NO=815412070589
CAMERA1_MARKER_PREFIX=tr_

# --- Camera 2 (Often Mounted on Panda wrist) ---
# --- UNCOMMENT THIS TO LAUNCH THIS CAMERA ---
